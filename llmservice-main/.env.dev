#Gemini API Key 
#발급 : 
GEMINI_API_KEY=YOUR_API_KEY

#기상청 단기 예보 API 
#서비스명 : 기상청_단기예보 조회서비스
#발급 : https://www.data.go.kr/iim/api/selectAPIAcountView.do
#주의 : 일반인증키(Decoding) 사용
KMA_API_KEY=YOUR_API_KEY
KMA_API_ENDPOINT=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0


#MySQL 설정 
MYSQL_HOST=localhost
MYSQL_PORT=YOUR_PORT
MYSQL_USER=YOUR_NAME
MYSQL_PASSWORD=YOUR_PW
MYSQL_DATABASE=clothing_db
